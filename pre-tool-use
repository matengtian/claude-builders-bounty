#!/usr/bin/env python3
"""
Claude Code pre-tool-use hook — blocks destructive bash commands.
Place at: ~/.claude/hooks/pre-tool-use
"""

import json, sys, os, re, time

LOG_FILE = os.path.expanduser('~/.claude/hooks/blocked.log')

DANGEROUS_PATTERNS = [
    (r'(^|\s)rm\s+(-[a-z]*r[a-z]*f|-[a-z]*f[a-z]*r)', 'rm -rf — recursive force delete'),
    (r'(?i)DROP\s+(TABLE|DATABASE|SCHEMA)', 'DROP TABLE/DATABASE — irreversible data loss'),
    (r'(?i)TRUNCATE\s+(TABLE\s+)?\w', 'TRUNCATE — deletes all rows without transaction log'),
    (r'git\s+push\s+(-f|--force)', 'git push --force — overwrites remote history'),
    (r'(?i)DELETE\s+FROM\s+\w+\s*$', 'DELETE FROM without WHERE — deletes entire table'),
    (r'(?i)chmod\s+777', 'chmod 777 — world-writable permissions'),
    (r'(?i)mkfs\.', 'mkfs — filesystem format'),
    (r'(?i)dd\s+if=', 'dd — raw disk write'),
    (r'(?i)>/dev/sd', 'write to raw block device'),
    (r'(?i)shutdown\s', 'shutdown — system power off'),
    (r'(?i)reboot\b', 'reboot — system restart'),
    (r'(?i):\(\)\s*\{\s*:\|:&\s*\};:', 'fork bomb'),
    (r'curl.*\|\s*(ba)?sh', 'curl pipe to shell — remote code execution risk'),
    (r'wget.*\|\s*(ba)?sh', 'wget pipe to shell — remote code execution risk'),
    (r'(?i)git\s+reset\s+--hard', 'git reset --hard — discards uncommitted work'),
    (r'(?i)chown\s+-R\s+root', 'chown -R root — recursive root ownership change'),
]


def log_block(command, project_path):
    os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
    entry = json.dumps({
        'timestamp': time.strftime('%Y-%m-%dT%H:%M:%SZ'),
        'command': command,
        'project': project_path,
    })
    with open(LOG_FILE, 'a') as f:
        f.write(entry + '\n')


def check_command(command):
    for pattern, description in DANGEROUS_PATTERNS:
        if re.search(pattern, command):
            return False, description
    return True, ''


def main():
    try:
        hook_input = json.load(sys.stdin)
    except json.JSONDecodeError:
        sys.exit(0)  # pass through on malformed input

    tool_name = hook_input.get('tool_name', '')
    tool_input = hook_input.get('tool_input', {})

    # Only intercept Bash tool calls
    if tool_name != 'Bash':
        sys.exit(0)

    command = tool_input.get('command', '')
    project_path = hook_input.get('cwd', os.getcwd())

    allowed, reason = check_command(command)

    if not allowed:
        log_block(command, project_path)

        block_message = json.dumps({
            'decision': 'block',
            'reason': f'Blocked destructive command: {reason}',
            'message': (
                f'Command blocked by safety guard.\n'
                f'  Blocked: {command[:200]}\n'
                f'  Reason:  {reason}\n'
                f'  Logged:  {LOG_FILE}\n\n'
                f'If this command is intentional, override by setting:\n'
                f'  CLAUDE_ALLOW_DANGEROUS=1'
            ),
        })
        print(block_message)
        sys.exit(2)  # exit code 2 = blocked

    sys.exit(0)  # exit code 0 = pass


if __name__ == '__main__':
    main()
